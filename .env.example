BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

NEXT_PUBLIC_COCKPIT_URL=http://localhost:3000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/start_cockpit"

# Google OAuth login. Required unless ENABLE_DEV_LOGIN=true (see below).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local development toggles. Both default to off — enable them ONLY in your
# local .env, never in a deployed environment.
# ENABLE_DEV_LOGIN: adds a passwordless "sign in by email" form at /auth that
# logs in any existing user with no verification. It only works on localhost and
# is hard-blocked when NODE_ENV=production. When set, GOOGLE_CLIENT_ID and
# GOOGLE_CLIENT_SECRET become optional and Google OAuth can be omitted.
# DISABLE_GOOGLE_WORKSPACE: turns all Admin SDK / Directory / Drive writes into
# no-ops and makes GOOGLE_APPLICATION_CREDENTIALS_BASE64 +
# GOOGLE_DRIVE_LEGAL_DOCUMENTS_FOLDER_ID optional.
ENABLE_DEV_LOGIN=false
DISABLE_GOOGLE_WORKSPACE=false

RESEND_API_KEY=

GOOGLE_APPLICATION_CREDENTIALS_BASE64=

SLACK_BOT_TOKEN=
NGROK_AUTH_TOKEN=

GOCARDLESS_API_KEY=
GOCARDLESS_BASE_URL=https://api-sandbox.gocardless.com
GOCARDLESS_WEBHOOK_SECRET=
