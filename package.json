{
  "name": "start-cockpit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run inngest:dev\" \"npm run next:dev\"",
    "next:dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "biome check",
    "test": "node --import tsx --test",
    "format": "biome format --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "db:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d",
    "db:dump": "dotenv -e .env -- sh -c 'pg_dump \"$DATABASE_URL\" --format=plain --no-owner --no-privileges --clean --if-exists --file supabase.sql'",
    "db:restore": "dotenv -e .env -- sh -c 'psql \"$DATABASE_URL\" < supabase.sql'",
    "google:add-member": "dotenv -e .env -- tsx scripts/google.ts",
    "email:dev": "dotenv -e .env -- email dev --dir src/emails",
    "email:test": "dotenv -e .env -- tsx scripts/send-test-email.ts",
    "docs:generate": "tsx scripts/generate-documents.tsx",
    "inngest:dev": "npx inngest-cli@latest dev",
    "env:pull": "npx vercel@54.0.0 env pull .env.local",
    "db:check": "drizzle-kit check --config=drizzle.config.ts",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1085.0",
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@next-safe-action/adapter-react-hook-form": "^2.0.6",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.5.1",
    "@slack/web-api": "^7.19.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "@xyflow/react": "^12.11.2",
    "bcryptjs": "^3.0.3",
    "better-all": "^0.0.7",
    "better-auth": "^1.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-seed": "^0.3.1",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-react": "^8.6.0",
    "gocardless-nodejs": "^8.4.0",
    "google-auth-library": "^10.9.0",
    "googleapis": "^173.0.0",
    "html-to-image": "^1.11.13",
    "i18n-iso-countries": "^7.14.0",
    "inngest": "^4.12.1",
    "input-otp": "^1.4.2",
    "libphonenumber-js": "^1.13.0",
    "lodash-es": "^4.18.1",
    "lodash.merge": "^4.6.2",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "16.2.6",
    "next-safe-action": "^8.5.2",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "nuqs": "^2.9.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "postcss": "^8.5.14",
    "posthog-js": "^1.399.2",
    "posthog-node": "^5.41.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.6",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.6",
    "react-email": "^6.7.0",
    "react-hook-form": "^7.81.0",
    "react-resizable-panels": "^4.12.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "recharts": "^3.9.2",
    "server-only": "^0.0.1",
    "slugify": "^1.6.9",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsscmp": "^1.0.6",
    "use-debounce": "^10.1.1",
    "usehooks-ts": "^3.1.1",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@react-email/ui": "6.7.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/lodash-es": "^4.17.12",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^26",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/tsscmp": "^1.0.2",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.4",
    "lint-staged": "^17.0.4",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": "biome check --write --no-errors-on-unmatched"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "tar": "7.5.11",
    "smol-toml": "1.6.1"
  }
}
